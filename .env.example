# ===========================================================================
# OpenSearch Lab — Configuração Telegram
# ===========================================================================
# Copie este arquivo para .env e preencha:
#   cp .env.example .env
#
# SETUP DO TELEGRAM:
#   1. Abra o Telegram e busque por @BotFather
#   2. Envie /newbot e siga as instruções para criar seu bot
#   3. Copie o TOKEN gerado e cole abaixo (TELEGRAM_BOT_TOKEN)
#   4. Envie uma mensagem qualquer (ex: "oi") para o seu novo bot
#   5. Acesse https://api.telegram.org/bot<SEU_TOKEN_AQUI>/getUpdates
#   6. Procure por "chat":{"id": e copie o número (ex: 123456789)
#   7. Cole esse número abaixo (TELEGRAM_CHAT_ID)
#   8. Rode: bash setup/06_alerting.sh
# ===========================================================================

# Token do BotFather
TELEGRAM_BOT_TOKEN=

# Seu ID de Chat
TELEGRAM_CHAT_ID=
